# NiceC WMS environment template
# Copy this file to .env and replace all placeholder values before deployment.

# Runtime
NODE_ENV=production
PORT=3000
APP_NAME="NiceC WMS"
APP_URL="https://wms.example.com"
API_BASE_URL="https://wms.example.com/api"
LOG_LEVEL=info
TRUST_PROXY=true

# Security - REQUIRED in production
# Generate with: openssl rand -base64 48
JWT_SECRET="replace-with-a-long-random-production-secret"
JWT_EXPIRES_IN="24h"
WEBHOOK_SECRET="replace-with-a-long-random-webhook-secret"
BCRYPT_SALT_ROUNDS=12
CORS_ORIGIN="https://wms.example.com"
ALLOWED_ORIGINS="https://wms.example.com"

# PostgreSQL / Prisma
# Docker Compose example:
DATABASE_URL="postgresql://nicec_wms:replace-db-password@postgres:5432/nicec_wms?schema=public"
POSTGRES_USER="nicec_wms"
POSTGRES_PASSWORD="replace-db-password"
POSTGRES_DB="nicec_wms"
POSTGRES_PORT=5432

# Initial admin/client seed accounts. Change before going live.
ADMIN_EMAIL="admin@nicec.net"
ADMIN_PASSWORD="replace-admin-password"
CLIENT_EMAIL="client@nicec.net"
CLIENT_PASSWORD="replace-client-password"

# JSON fallback: allows the app to run without a database (for demo/dev).
# MUST be false in production.
ENABLE_JSON_FALLBACK=false
ENABLE_DEMO_LOGIN=false
MOCK_MODE=false

# AI Assistant. Leave provider as mock until a real key is configured.
AI_PROVIDER="mock"
GOOGLE_GENAI_API_KEY=""
GOOGLE_API_KEY=""
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"
LLM_TIMEOUT_MS=15000
OPENROUTER_API_KEY=""
APIPLANT_API_KEY=""
APIPLANT_BASE_URL=""
AI_MODEL="gemini-3.5-flash"

# Email / Notification
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="no-reply@nicec-wms.local"

# File Storage
STORAGE_PROVIDER="local"
LOCAL_UPLOAD_DIR="./uploads"
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_REGION="us-east-1"
CLOUDFLARE_R2_ACCOUNT_ID=""
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET=""

# Shipping Providers - optional, mock first
SHIPPING_PROVIDER="mock"
EASYPOST_API_KEY=""
SHIPPO_API_KEY=""
FEDEX_API_KEY=""
FEDEX_SECRET=""
FEDEX_ACCOUNT_NUMBER=""
UPS_CLIENT_ID=""
UPS_CLIENT_SECRET=""
UPS_ACCOUNT_NUMBER=""
USPS_CLIENT_ID=""
USPS_CLIENT_SECRET=""

# Store Integrations - optional, mock first
SHOPIFY_CLIENT_ID=""
SHOPIFY_CLIENT_SECRET=""
AMAZON_SP_API_CLIENT_ID=""
AMAZON_SP_API_CLIENT_SECRET=""
AMAZON_SP_API_REFRESH_TOKEN=""
TIKTOK_SHOP_CLIENT_KEY=""
TIKTOK_SHOP_CLIENT_SECRET=""
WALMART_CLIENT_ID=""
WALMART_CLIENT_SECRET=""
TEMU_CLIENT_ID=""
TEMU_CLIENT_SECRET=""
SHEIN_CLIENT_ID=""
SHEIN_CLIENT_SECRET=""
