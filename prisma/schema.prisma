// Prisma Database Schema for Linkstar WMS
// Target Database: PostgreSQL

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  WAREHOUSE_MANAGER
  WAREHOUSE_OPERATOR
  CLIENT
}

enum OrderStatus {
  PENDING
  PICKING
  REVIEWS
  SHIPPING
  SHIPPED
  EXCEPTIONS
  CANCELLED
}

enum PrintStatus {
  PRINTED
  NOT_PRINTED
}

model User {
  id          String     @id @default(uuid())
  username    String     @unique
  email       String     @unique
  passwordHash String     // Hash value
  role        Role       @default(WAREHOUSE_OPERATOR)
  avatar      String?
  customerId  String?
  customer    Customer?  @relation(fields: [customerId], references: [id])
  warehouseId String?
  status      String     @default("ACTIVE")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Warehouse {
  id          String      @id @default(uuid())
  name        String
  code        String      @unique
  address     String
  inventories Inventory[]
  locations   Location[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Customer {
  id           String                 @id @default(uuid())
  name         String
  code         String                 @unique // e.g. Yukon(1108037)
  contact      String?
  email        String?
  orders       OutboundOrder[]
  inboundOrders InboundOrder[]
  skus         SKU[]
  products     Product[]
  users        User[]
  inventories  Inventory[]
  reservations InventoryReservation[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
}

model Product {
  id         String   @id @default(uuid())
  name       String
  sku        String   @unique
  barcode    String?
  category   String?
  weight     Float    @default(0.0) // in kg
  volume     Float    @default(0.0) // in m³
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SKU {
  id         String              @id @default(uuid())
  code       String              @unique
  name       String
  barcode    String
  weight     Float               @default(0.0)
  customerId String
  customer   Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items      OutboundOrderItem[]
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
}

model OutboundOrder {
  id                 String              @id @default(uuid())
  orderNo            String              @unique // OBSXXXXXXXXXX
  status             OrderStatus         @default(PENDING)
  remark             String              @default("-")
  totalWeight        Float               @default(0.0)
  totalQty           Int                 @default(0)
  customerId         String
  customer           Customer            @relation(fields: [customerId], references: [id])
  logisticsChannelId String
  logisticsChannel   LogisticsChannel    @relation(fields: [logisticsChannelId], references: [id])
  carrierId          String
  carrier            Carrier             @relation(fields: [carrierId], references: [id])
  waveId             String?
  wave               Wave?               @relation(fields: [waveId], references: [id], onDelete: SetNull)
  labelPrinted       PrintStatus         @default(NOT_PRINTED)
  recipient          String
  salesPlatform      String              @default("Amazon")
  orderType          String              @default("单品单件")
  items              OutboundOrderItem[]
  shipment           Shipment?
  createdTime        DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([status])
  @@index([orderNo])
}

model OutboundOrderItem {
  id          String        @id @default(uuid())
  orderId     String
  order       OutboundOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  skuId       String
  sku         SKU           @relation(fields: [skuId], references: [id])
  skuCode     String
  skuBarcode  String
  qty         Int           @default(1)
  productName String
  category    String        @default("未分类")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Wave {
  id         String          @id @default(uuid())
  waveNo     String          @unique // WVXXXXXXXXXX
  status     String          @default("PENDING") // PENDING, PICKING, COMPLETED
  orderCount Int             @default(0)
  orders     OutboundOrder[]
  createdTime DateTime       @default(now())
  updatedAt  DateTime        @updatedAt
}

model Carrier {
  id       String             @id @default(uuid())
  name     String
  code     String             @unique // FEDEX, USPS, UPS
  channels LogisticsChannel[]
  orders   OutboundOrder[]
}

model LogisticsChannel {
  id        String          @id @default(uuid())
  name      String
  code      String          @unique
  carrierId String
  carrier   Carrier         @relation(fields: [carrierId], references: [id], onDelete: Cascade)
  orders    OutboundOrder[]
}

model Shipment {
  id          String        @id @default(uuid())
  orderId     String        @unique
  order       OutboundOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  trackingNo  String        @unique
  cost        Float         @default(0.0)
  shippedTime DateTime      @default(now())
}

model Feedback {
  id                 String            @id @default(uuid())
  organizationId     String?
  userId             String
  warehouseId        String?
  operationScope     String?
  type               String
  title              String
  description        String
  relatedPage        String
  priority           String
  status             String            @default("New")
  screenshotUrl      String?
  contactEmail       String
  browserInfo        String?
  deviceInfo         String?
  assignedToUserId   String?
  internalNotes      String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  resolvedAt         DateTime?
  comments           FeedbackComment[]
}

model FeedbackComment {
  id         String   @id @default(uuid())
  feedbackId String
  feedback   Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  userId     String
  comment    String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Inventory {
  id           String    @id @default(uuid())
  customerId   String
  customer     Customer  @relation(fields: [customerId], references: [id])
  skuId        String
  skuCode      String
  warehouseId  String
  warehouse    Warehouse @relation(fields: [warehouseId], references: [id])
  availableQty Int       @default(0)
  reservedQty  Int       @default(0)
  damagedQty   Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([skuId, warehouseId])
}

model InventoryTransaction {
  id             String   @id @default(uuid())
  customerId     String
  warehouseId    String
  skuId          String
  skuCode        String
  type           String   // INBOUND_RECEIVED, PUTAWAY, OUTBOUND_RESERVED, OUTBOUND_SHIPPED, ORDER_CANCEL_RELEASE, etc.
  direction      String   // IN, OUT, LOCK, RELEASE
  quantity       Int
  beforeQty      Int
  afterQty       Int
  referenceType  String?
  referenceId    String?
  reason         String?
  operatorUserId String?
  createdAt      DateTime @default(now())
}

model InventoryReservation {
  id          String    @id @default(uuid())
  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id])
  orderId     String
  orderItemId String?
  skuId       String
  skuCode     String
  warehouseId String
  quantity    Int
  status      String    // ACTIVE, RELEASED, CONSUMED
  createdAt   DateTime  @default(now())
  releasedAt  DateTime?
}

model Location {
  id          String    @id @default(uuid())
  code        String    @unique // e.g. ZONE-A-1-1
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  zoneCode    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model InventoryLocation {
  id           String    @id @default(uuid())
  warehouseId  String
  locationId   String
  skuId        String
  skuCode      String
  availableQty Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model InboundOrder {
  id           String             @id @default(uuid())
  orderNo      String             @unique // ASNXXXXXXXXXX
  customerId   String
  customer     Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  status       String             @default("PENDING") // PENDING, SUBMITTED, RECEIVED, CANCELLED
  warehouseId  String
  remark       String             @default("-")
  items        InboundOrderItem[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model InboundOrderItem {
  id             String       @id @default(uuid())
  orderId        String
  order          InboundOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  skuId          String
  skuCode        String
  qtyExpected    Int          @default(0)
  qtyReceived    Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model PutawayTask {
  id             String    @id @default(uuid())
  taskNo         String    @unique // PAXXXXXXXXXX
  inboundOrderId String?
  skuId          String
  skuCode        String
  warehouseId    String
  locationId     String?
  quantity       Int
  status         String    @default("PENDING") // PENDING, PROCESSING, COMPLETED
  operatorId     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model PickTask {
  id          String    @id @default(uuid())
  taskNo      String    @unique // PKXXXXXXXXXX
  waveId      String?
  orderId     String?
  skuId       String
  skuCode     String
  warehouseId String
  quantity    Int
  status      String    @default("PENDING") // PENDING, PROCESSING, COMPLETED
  operatorId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ReviewTask {
  id          String    @id @default(uuid())
  orderId     String    @unique
  status      String    @default("PENDING") // PENDING, COMPLETED
  operatorId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Package {
  id          String    @id @default(uuid())
  packageNo   String    @unique // PKGXXXXXXXXXX
  orderId     String
  weight      Float     @default(0.0)
  length      Float     @default(0.0)
  width       Float     @default(0.0)
  height      Float     @default(0.0)
  trackingNo  String?
  labelUrl    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ExceptionCase {
  id          String    @id @default(uuid())
  caseNo      String    @unique // EXCXXXXXXXXXX
  orderId     String?
  customerId  String?
  type        String    // e.g. DAMAGED_ON_ARRIVAL, ADDRESS_ERROR
  description String
  status      String    @default("PENDING") // PENDING, RESOLVED
  resolution  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ReturnOrder {
  id           String       @id @default(uuid())
  returnNo     String       @unique // RTXXXXXXXXXX
  orderId      String?
  customerId   String
  status       String       @default("PENDING") // PENDING, RECEIVED, PROCESSED
  items        ReturnItem[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model ReturnItem {
  id            String      @id @default(uuid())
  returnOrderId String
  returnOrder   ReturnOrder @relation(fields: [returnOrderId], references: [id], onDelete: Cascade)
  skuId         String
  skuCode       String
  qtyExpected   Int         @default(0)
  qtyReceived   Int         @default(0)
  condition     String      @default("RESTOCK") // RESTOCK, DAMAGED
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model RelabelOrder {
  id          String    @id @default(uuid())
  orderNo     String    @unique // RLXXXXXXXXXX
  customerId  String
  skuId       String
  oldSkuCode  String
  newSkuCode  String
  quantity    Int
  status      String    @default("PENDING") // PENDING, COMPLETED
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model WorkOrder {
  id          String    @id @default(uuid())
  orderNo     String    @unique // WOXXXXXXXXXX
  customerId  String
  type        String    // PHOTO, LABELLING, DESTRUCTION
  description String
  status      String    @default("PENDING") // PENDING, COMPLETED
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model BillingRule {
  id          String    @id @default(uuid())
  name        String
  code        String    @unique // e.g. OUTBOUND_FEE, STORAGE_FEE
  type        String    // e.g. OUTBOUND, STORAGE, INBOUND
  rate        Float     @default(0.0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model BillingRecord {
  id          String    @id @default(uuid())
  customerId  String
  orderId     String?
  type        String    // OUTBOUND, STORAGE, INBOUND
  amount      Float     @default(0.0)
  currency    String    @default("USD")
  status      String    @default("UNPAID") // UNPAID, PAID
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Invoice {
  id          String    @id @default(uuid())
  invoiceNo   String    @unique // INVXXXXXXXXXX
  customerId  String
  amount      Float     @default(0.0)
  status      String    @default("UNPAID") // UNPAID, PAID
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ApiKey {
  id          String    @id @default(uuid())
  customerId  String
  key         String    @unique
  status      String    @default("ACTIVE")
  createdAt   DateTime  @default(now())
}

model WebhookEndpoint {
  id          String    @id @default(uuid())
  customerId  String
  url         String
  secret      String
  status      String    @default("ACTIVE")
  createdAt   DateTime  @default(now())
}

model WebhookEvent {
  id          String    @id @default(uuid())
  customerId  String
  eventType   String
  payload     String    // JSON string
  status      String    @default("PENDING") // PENDING, SENT, FAILED
  createdAt   DateTime  @default(now())
}

model StoreConnection {
  id          String    @id @default(uuid())
  customerId  String
  platform    String    // SHOPIFY, AMAZON, TIKTOK, WALMART, TEMU, SHEIN
  shopName    String
  status      String    @default("ACTIVE")
  createdAt   DateTime  @default(now())
}

model ShippingProvider {
  id          String    @id @default(uuid())
  name        String
  code        String    @unique // EASYPOST, SHIPPO, FEDEX
  status      String    @default("ACTIVE")
  createdAt   DateTime  @default(now())
}

model OperationLog {
  id          String    @id @default(uuid())
  userId      String
  username    String
  action      String
  details     String?
  ipAddress   String?
  createdAt   DateTime  @default(now())
}

model AuditLog {
  id          String    @id @default(uuid())
  userId      String
  action      String
  resource    String
  resourceId  String?
  changes     String?   // JSON string
  createdAt   DateTime  @default(now())
}

