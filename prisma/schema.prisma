// Prisma Database Schema for Linkstar WMS
// Target Database: PostgreSQL

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  admin
  operator
  manager
}

enum OrderStatus {
  PENDING
  PICKING
  REVIEWS
  SHIPPING
  SHIPPED
  EXCEPTIONS
  CANCELLED
}

enum PrintStatus {
  PRINTED
  NOT_PRINTED
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String   // Hash value
  role      Role     @default(operator)
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Warehouse {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  address   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id        String          @id @default(uuid())
  name      String
  code      String          @unique // e.g. Yukon(1108037)
  contact   String?
  email     String?
  orders    OutboundOrder[]
  skus      SKU[]
  products  Product[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model Product {
  id         String   @id @default(uuid())
  name       String
  sku        String   @unique
  barcode    String?
  category   String?
  weight     Float    @default(0.0) // in kg
  volume     Float    @default(0.0) // in m³
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SKU {
  id         String              @id @default(uuid())
  code       String              @unique
  name       String
  barcode    String
  weight     Float               @default(0.0)
  customerId String
  customer   Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items      OutboundOrderItem[]
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
}

model OutboundOrder {
  id                 String              @id @default(uuid())
  orderNo            String              @unique // OBSXXXXXXXXXX
  status             OrderStatus         @default(PENDING)
  remark             String              @default("-")
  totalWeight        Float               @default(0.0)
  totalQty           Int                 @default(0)
  customerId         String
  customer           Customer            @relation(fields: [customerId], references: [id])
  logisticsChannelId String
  logisticsChannel   LogisticsChannel    @relation(fields: [logisticsChannelId], references: [id])
  carrierId          String
  carrier            Carrier             @relation(fields: [carrierId], references: [id])
  waveId             String?
  wave               Wave?               @relation(fields: [waveId], references: [id], onDelete: SetNull)
  labelPrinted       PrintStatus         @default(NOT_PRINTED)
  recipient          String
  salesPlatform      String              @default("Amazon")
  orderType          String              @default("单品单件")
  items              OutboundOrderItem[]
  shipment           Shipment?
  createdTime        DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([status])
  @@index([orderNo])
}

model OutboundOrderItem {
  id          String        @id @default(uuid())
  orderId     String
  order       OutboundOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  skuId       String
  sku         SKU           @relation(fields: [skuId], references: [id])
  skuCode     String
  skuBarcode  String
  qty         Int           @default(1)
  productName String
  category    String        @default("未分类")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Wave {
  id         String          @id @default(uuid())
  waveNo     String          @unique // WVXXXXXXXXXX
  status     String          @default("PENDING") // PENDING, PICKING, COMPLETED
  orderCount Int             @default(0)
  orders     OutboundOrder[]
  createdTime DateTime       @default(now())
  updatedAt  DateTime        @updatedAt
}

model Carrier {
  id       String             @id @default(uuid())
  name     String
  code     String             @unique // FEDEX, USPS, UPS
  channels LogisticsChannel[]
  orders   OutboundOrder[]
}

model LogisticsChannel {
  id        String          @id @default(uuid())
  name      String
  code      String          @unique
  carrierId String
  carrier   Carrier         @relation(fields: [carrierId], references: [id], onDelete: Cascade)
  orders    OutboundOrder[]
}

model Shipment {
  id          String        @id @default(uuid())
  orderId     String        @unique
  order       OutboundOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  trackingNo  String        @unique
  cost        Float         @default(0.0)
  shippedTime DateTime      @default(now())
}

model Feedback {
  id                 String            @id @default(uuid())
  organizationId     String?
  userId             String
  warehouseId        String?
  operationScope     String?
  type               String
  title              String
  description        String
  relatedPage        String
  priority           String
  status             String            @default("New")
  screenshotUrl      String?
  contactEmail       String
  browserInfo        String?
  deviceInfo         String?
  assignedToUserId   String?
  internalNotes      String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  resolvedAt         DateTime?
  comments           FeedbackComment[]
}

model FeedbackComment {
  id         String   @id @default(uuid())
  feedbackId String
  feedback   Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  userId     String
  comment    String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
}

